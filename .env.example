# AirOps API Key
# 单 key：
AIROPS_API_KEY=
# 多 key 轮换（逗号分隔，优先于上面的单 key）：
# AIROPS_API_KEYS=key1,key2,key3

# 可选：上游 base url，默认 https://api.airops.com
# AIROPS_BASE_URL=https://api.airops.com

# 保护本代理的访问令牌；监听非本机地址时必须设置
# PROXY_TOKEN=

# 可选：/run 和 /v1/chat/completions 的轮询间隔与超时（秒）
# POLL_INTERVAL=2
# POLL_TIMEOUT=600

# 可选：key 轮换冷却时间（秒，遇到 429 后该 key 暂时跳过这么久）
# AIROPS_KEY_COOLDOWN=60

# OpenAI /v1/models 对外只暴露这一层统一模型名
# AIROPS_PUBLIC_MODEL=fable5
# 使用该模型名的请求会按 config.json 顺序轮询所有已启用 workflow

# 可选：配置文件路径，默认 config.json（由管理面板自动维护）
# CONFIG_PATH=config.json

# Docker 默认仅发布到宿主机本地 8081 端口
# DOCKER_BIND_HOST=127.0.0.1
# DOCKER_PORT=8081
# 若将 DOCKER_BIND_HOST 改为 0.0.0.0，务必同时设置 PROXY_TOKEN
